# godozo config — copy to `.env` and fill in. Telegram is the v0 channel.
#
#   1. Message @BotFather on Telegram → /newbot → copy the token below.
#   2. Message @userinfobot → it replies with your numeric chat id.
#   3. Send your new bot any message once (so it's allowed to DM you).
#
GODOZO_TELEGRAM_TOKEN=123456:ABC-your-bot-token-from-BotFather
GODOZO_TELEGRAM_CHAT_ID=your-numeric-chat-id

# --- Slack (set GODOZO_CHANNEL=slack to use it instead of Telegram) ---
# Create a Slack app, add bot scope chat:write, install to the workspace,
# invite the bot to the channel, and copy the channel ID (View channel details).
# GODOZO_CHANNEL=slack
# GODOZO_SLACK_BOT_TOKEN=xoxb-your-bot-token
# GODOZO_SLACK_CHANNEL=C0123456789

# Optional
GODOZO_LABEL=godozo
GODOZO_DEFAULT_TIMEOUT=600
